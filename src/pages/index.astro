---
import { getCollection } from 'astro:content';
import BlogLayout from '../layouts/BlogLayout.astro';

// 获取最新 3 篇文章
const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

// 格式化日期
const formatDate = (date: Date) => {
  return date.toLocaleDateString('zh-CN', {
    month: 'short',
    day: 'numeric',
  });
};
---

<BlogLayout title="首页">
  <section class="hero">
    {/* 动态背景光效 */}
    <div class="hero-bg-effects">
      <div class="orb orb-1"></div>
      <div class="orb orb-2"></div>
      <div class="orb orb-3"></div>
    </div>
    
    <div class="container">
      <div class="hero-content">
        <div class="hero-badge animate-fade-in-up">
          <span class="badge-dot"></span>
          <span class="mono">Frontend Developer</span>
        </div>
        
        <h1 class="hero-title animate-fade-in-up stagger-1">
          探索前端技术的<br />
          <span class="text-gradient">无限可能</span>
        </h1>
        
        <p class="hero-description animate-fade-in-up stagger-2">
          专注于现代前端技术栈，用代码构建优雅的用户体验。
          从框架原理到性能优化，记录每一个成长的瞬间。
        </p>
        
        <div class="hero-actions animate-fade-in-up stagger-3">
          <a href="/blog" class="btn btn-primary magnetic-btn">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/>
            </svg>
            浏览文章
          </a>
          <a href="/about" class="btn btn-ghost magnetic-btn">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <path d="M12 16v-4"/>
              <path d="M12 8h.01"/>
            </svg>
            关于我
          </a>
        </div>
      </div>
      
      <div class="hero-decoration animate-fade-in-up stagger-4">
        <div class="decoration-grid">
          <div class="decoration-card glass-card glow-border">
            <span class="decoration-number text-gradient">{posts.length}+</span>
            <span class="decoration-label">精选文章</span>
            <div class="card-shine"></div>
          </div>
          <div class="decoration-card glass-card glow-border">
            <span class="decoration-number text-gradient">∞</span>
            <span class="decoration-label">持续学习</span>
            <div class="card-shine"></div>
          </div>
          <div class="decoration-card glass-card glow-border">
            <span class="decoration-number text-gradient">100%</span>
            <span class="decoration-label">技术热情</span>
            <div class="card-shine"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="recent-posts">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">
          <span class="title-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
            </svg>
          </span>
          最新文章
        </h2>
        <a href="/blog" class="section-link">
          查看全部
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14"/>
            <path d="m12 5 7 7-7 7"/>
          </svg>
        </a>
      </div>
      
      <div class="posts-grid">
        {posts.map((post, index) => (
          <a href={`/blog/${post.id}`} class={`post-card glass-card animate-fade-in-up stagger-${index + 1}`}>
            <div class="post-card-glow"></div>
            <div class="post-card-inner">
              <div class="post-card-meta">
                <time class="post-card-date mono">{formatDate(post.data.pubDate)}</time>
                <span class="tag">{post.data.tags[0]}</span>
              </div>
              <h3 class="post-card-title">{post.data.title}</h3>
              <p class="post-card-description">{post.data.description}</p>
              <div class="post-card-footer">
                <span class="read-more">
                  阅读全文
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M5 12h14"/>
                    <path d="m12 5 7 7-7 7"/>
                  </svg>
                </span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
  
  {/* 技术栈展示区 */}
  <section class="tech-stack">
    <div class="container">
      <h3 class="tech-title">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m16 18 6-6-6-6"/>
          <path d="M8 6l-6 6 6 6"/>
        </svg>
        技术栈
      </h3>
      <div class="tech-grid">
        <div class="tech-category">
          <span class="tech-category-title">核心技能</span>
          <div class="tech-tags">
            <span class="tech-tag">HTML5</span>
            <span class="tech-tag">CSS3</span>
            <span class="tech-tag">JavaScript</span>
            <span class="tech-tag">TypeScript</span>
          </div>
        </div>
        <div class="tech-category">
          <span class="tech-category-title">前端框架</span>
          <div class="tech-tags">
            <span class="tech-tag primary">Vue3</span>
            <span class="tech-tag">React</span>
            <span class="tech-tag">React Native</span>
            <span class="tech-tag">Uni-app</span>
          </div>
        </div>
        <div class="tech-category">
          <span class="tech-category-title">构建工具</span>
          <div class="tech-tags">
            <span class="tech-tag primary">Vite</span>
            <span class="tech-tag">Webpack</span>
            <span class="tech-tag">Element UI</span>
            <span class="tech-tag">Ant Design</span>
            <span class="tech-tag">Vant</span>
          </div>
        </div>
        <div class="tech-category">
          <span class="tech-category-title">其他技能</span>
          <div class="tech-tags">
            <span class="tech-tag">Canvas</span>
            <span class="tech-tag">Three.js</span>
            <span class="tech-tag">Electron</span>
            <span class="tech-tag">Sass/Less</span>
            <span class="tech-tag">Git</span>
          </div>
        </div>
      </div>
    </div>
  </section>
</BlogLayout>

<style>
  /* Hero Section */
  .hero {
    position: relative;
    padding: var(--space-4xl) 0;
    min-height: 85vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  /* 背景光效 */
  .hero-bg-effects {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.6;
    animation: orbFloat 20s ease-in-out infinite;
  }

  .orb-1 {
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(88, 166, 255, 0.4) 0%, transparent 70%);
    top: -200px;
    left: -100px;
    animation-delay: 0s;
  }

  .orb-2 {
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(163, 113, 247, 0.3) 0%, transparent 70%);
    top: 20%;
    right: -100px;
    animation-delay: -7s;
  }

  .orb-3 {
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(126, 231, 135, 0.25) 0%, transparent 70%);
    bottom: 0;
    left: 30%;
    animation-delay: -14s;
  }

  @keyframes orbFloat {
    0%, 100% { transform: translate(0, 0) scale(1); }
    25% { transform: translate(30px, -30px) scale(1.05); }
    50% { transform: translate(-20px, 20px) scale(0.95); }
    75% { transform: translate(20px, 30px) scale(1.02); }
  }

  .hero .container {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--space-4xl);
    align-items: center;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-xs) var(--space-md);
    background: rgba(88, 166, 255, 0.1);
    border: 1px solid rgba(88, 166, 255, 0.2);
    border-radius: 100px;
    font-size: 0.75rem;
    color: var(--color-accent);
    margin-bottom: var(--space-lg);
    backdrop-filter: blur(10px);
  }

  .badge-dot {
    width: 8px;
    height: 8px;
    background: var(--color-accent);
    border-radius: 50%;
    animation: pulse-glow 2s ease-in-out infinite;
    box-shadow: 0 0 10px var(--color-accent);
  }

  .hero-title {
    margin-bottom: var(--space-lg);
    font-size: clamp(2.5rem, 6vw, 4rem);
    line-height: 1.1;
  }

  .hero-description {
    max-width: 540px;
    font-size: 1.125rem;
    line-height: 1.8;
    margin-bottom: var(--space-xl);
  }

  .hero-actions {
    display: flex;
    gap: var(--space-md);
  }

  /* 装饰卡片 */
  .hero-decoration {
    opacity: 0;
  }

  .decoration-grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .decoration-card {
    position: relative;
    padding: var(--space-lg) var(--space-xl);
    border-radius: var(--radius-lg);
    text-align: center;
    min-width: 150px;
    overflow: hidden;
  }

  .card-shine {
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.05), transparent);
    animation: shimmer 4s ease-in-out infinite;
  }

  .decoration-number {
    display: block;
    font-size: 2rem;
    font-weight: 800;
    font-family: var(--font-mono);
  }

  .decoration-label {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  /* Recent Posts Section */
  .recent-posts {
    padding: var(--space-4xl) 0;
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-2xl);
  }

  .section-title {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: 1.5rem;
  }

  .title-icon {
    color: var(--color-accent);
    animation: pulse-glow 3s ease-in-out infinite;
  }

  .section-link {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    transition: all var(--transition-base);
  }

  .section-link:hover {
    color: var(--color-accent);
    gap: var(--space-sm);
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
    gap: var(--space-lg);
  }

  .post-card {
    position: relative;
    display: flex;
    flex-direction: column;
    border-radius: var(--radius-xl);
    overflow: hidden;
    opacity: 0;
  }

  .post-card-glow {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--gradient-primary);
    opacity: 0;
    transition: opacity var(--transition-base);
  }

  .post-card:hover .post-card-glow {
    opacity: 1;
  }

  .post-card-inner {
    position: relative;
    z-index: 1;
    padding: var(--space-xl);
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .post-card-meta {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-md);
  }

  .post-card-date {
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  .post-card-title {
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: var(--space-sm);
    transition: color var(--transition-fast);
  }

  .post-card:hover .post-card-title {
    color: var(--color-accent);
  }

  .post-card-description {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    flex-grow: 1;
    margin-bottom: var(--space-md);
  }

  .post-card-footer {
    margin-top: auto;
  }

  .read-more {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text-muted);
    transition: all var(--transition-base);
  }

  .post-card:hover .read-more {
    color: var(--color-accent);
    gap: var(--space-sm);
  }

  /* Tech Stack Section */
  .tech-stack {
    padding: var(--space-4xl) 0;
    border-top: 1px solid var(--color-border);
  }

  .tech-title {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    font-size: 1.25rem;
    margin-bottom: var(--space-2xl);
    color: var(--color-text);
  }

  .tech-title svg {
    color: var(--color-accent);
  }

  .tech-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-lg);
    max-width: 900px;
    margin: 0 auto;
  }

  .tech-category {
    padding: var(--space-lg);
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    transition: all var(--transition-base);
  }

  .tech-category:hover {
    border-color: var(--color-border-subtle);
    transform: translateY(-4px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
  }

  .tech-category-title {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    margin-bottom: var(--space-md);
  }

  .tech-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .tech-tag {
    display: inline-block;
    padding: var(--space-xs) var(--space-sm);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    transition: all var(--transition-fast);
    cursor: default;
  }

  .tech-tag:hover {
    color: var(--color-text);
    border-color: var(--color-text-muted);
  }

  .tech-tag.primary {
    color: var(--color-accent);
    background: var(--color-accent-subtle);
    border-color: rgba(88, 166, 255, 0.3);
  }

  .tech-tag.primary:hover {
    border-color: var(--color-accent);
    box-shadow: 0 0 15px rgba(88, 166, 255, 0.3);
  }

  /* Responsive */
  @media (max-width: 900px) {
    .hero .container {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .hero-description {
      margin-left: auto;
      margin-right: auto;
    }

    .hero-actions {
      justify-content: center;
    }

    .hero-decoration {
      display: none;
    }

    .posts-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .hero {
      padding: var(--space-3xl) 0;
      min-height: auto;
    }

    .hero-actions {
      flex-direction: column;
      width: 100%;
    }

    .hero-actions .btn {
      width: 100%;
      justify-content: center;
    }

    .tech-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
